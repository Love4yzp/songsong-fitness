---
import { url } from '../utils/url';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  type?: 'website' | 'article';
  hideNav?: boolean;
  hideFooter?: boolean;
}

const {
  title,
  description = '松松健身：好人松松的健身饮食方法论结构化呈现。',
  type = 'website',
  hideNav = false,
  hideFooter = false,
} = Astro.props;

const currentPath = Astro.url.pathname;

const primaryNav = [
  { href: url('/calculator'), label: '计算器' },
  { href: url('/plan'), label: '饮食方案' },
];

const moreNav = [
  { href: url('/food'), label: '食物数据库' },
  { href: url('/learn'), label: '理解体系' },
  { href: url('/qa'), label: '常见问题' },
  { href: url('/training'), label: '训练计划' },
  { href: url('/about'), label: '关于本站' },
];
---

<!doctype html>
<html lang="zh-CN" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#18181b" id="meta-theme-color" />
    <script is:inline>
      // 防闪烁：在 DOM 解析前同步设置主题
      ;(function() {
        var stored = localStorage.getItem('theme');
        var dark = stored === 'dark' || (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches);
        if (!dark) document.documentElement.classList.remove('dark');
        document.getElementById('meta-theme-color')
          ?.setAttribute('content', dark ? '#18181b' : '#ffffff');
      })();
    </script>
    <link rel="icon" type="image/svg+xml" href={url('/favicon.svg')} />
    <link rel="apple-touch-icon" href={url('/apple-touch-icon.png')} />
    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:locale" content="zh_CN" />
    <meta property="og:site_name" content="松松健身" />
  </head>
  <body class="bg-bg text-fg selection:bg-accent/30 selection:text-accent">
    {!hideNav && (
      <header class="sticky top-0 z-50 bg-bg/80 backdrop-blur-md border-b border-border">
        <div class="container h-14 flex items-center justify-between">
          <a href={url('/')} class="flex items-center gap-2 group">
            <div class="w-8 h-8 bg-accent rounded-lg flex items-center justify-center text-white font-bold text-lg group-hover:scale-105 transition-transform shadow-lg shadow-accent/20">
              S
            </div>
            <span class="font-bold text-lg tracking-tight hidden sm:inline-block">松松健身</span>
          </a>

          <nav class="flex items-center gap-6">
            <button
              data-theme-toggle
              class="w-8 h-8 flex items-center justify-center rounded-lg text-fg-secondary hover:text-fg hover:bg-bg-tertiary transition-colors"
              title="切换主题"
              aria-label="切换亮色/暗色主题"
            >
              <svg class="w-4 h-4 dark:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
              <svg class="w-4 h-4 hidden dark:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
            </button>
            {primaryNav.map(({ href, label }) => (
              <a
                href={href}
                class:list={[
                  'text-sm font-medium transition-colors',
                  currentPath.startsWith(href) ? 'text-accent' : 'text-fg-secondary hover:text-fg',
                ]}
              >
                {label}
              </a>
            ))}
            <div class="relative group/more" id="more-nav-container">
              <button
                id="more-nav-btn"
                class="text-sm font-medium text-fg-secondary group-hover/more:text-fg flex items-center gap-0.5"
                aria-expanded="false"
                aria-haspopup="true"
              >
                更多
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 5l3 3 3-3" /></svg>
              </button>
              <div
                id="more-nav-menu"
                class="absolute right-0 top-full pt-2 hidden group-hover/more:block"
              >
                <div class="bg-bg-secondary rounded-xl border border-border shadow-xl py-1.5 min-w-40">
                  {moreNav.map(({ href, label }) => (
                    <a
                      href={href}
                      class:list={[
                        'block px-4 py-2 text-sm transition-colors',
                        currentPath.startsWith(href) ? 'text-accent font-medium bg-bg-tertiary/50' : 'text-fg-secondary hover:text-fg hover:bg-bg-tertiary/50',
                      ]}
                    >
                      {label}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          </nav>
        </div>
      </header>
    )}

    <main>
      <slot />
    </main>

    {!hideFooter && (
      <footer class="border-t border-border mt-20 bg-bg-secondary/30">
        <div class="container py-10 text-fg-tertiary text-xs flex flex-col sm:flex-row justify-between gap-4">
          <div class="space-y-1">
            <p>内容基于 <a href="https://space.bilibili.com/2078781964" target="_blank" class="underline decoration-dotted hover:text-accent transition-colors">B站@好人松松</a> 的健身方法论</p>
            <p>&copy; {new Date().getFullYear()} 松松健身</p>
          </div>
          <p>本站开源 · 不提供医疗建议</p>
        </div>
      </footer>
    )}
    <script is:inline>
      // 主题切换 — 所有带 data-theme-toggle 的按钮共享逻辑
      document.addEventListener('click', function(e) {
        var btn = e.target.closest('[data-theme-toggle]');
        if (!btn) return;
        var html = document.documentElement;
        var isDark = html.classList.contains('dark');
        html.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'light' : 'dark');
        var meta = document.getElementById('meta-theme-color');
        if (meta) meta.setAttribute('content', isDark ? '#ffffff' : '#18181b');
      });
    </script>
  </body>
</html>
