---
import { url } from '../utils/url';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
}

const {
  title,
  description = '好人松松的饮食方法——用配额吃饭，而不是算热量。',
  image = '/og-image.png',
  type = 'website',
  noindex = false,
} = Astro.props;
const currentPath = Astro.url.pathname;
const siteURL = Astro.site?.toString() || 'https://love4yzp.github.io';
const canonicalURL = new URL(currentPath, siteURL);
const ogImageURL = new URL(image, siteURL);

const primaryNav = [
  { href: url('/calculator'), label: '计算器' },
  { href: url('/plan'), label: '方案' },
  { href: url('/food'), label: '食物' },
];

const moreNav = [
  { href: url('/learn/philosophy'), label: '理解体系' },
  { href: url('/training'), label: '训练' },
  { href: url('/qa'), label: '常见问题' },
  { href: url('/about'), label: '关于' },
];
---

<!doctype html>
<html lang="zh-CN" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#1a1a1a" media="(prefers-color-scheme: dark)" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    
    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href={url('/favicon.svg')} />
    <link rel="apple-touch-icon" href={url('/apple-touch-icon.png')} />
    
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:locale" content="zh_CN" />
    <meta property="og:site_name" content="松松健身" />
    
    <!-- Twitter Cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    
    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': type === 'article' ? 'Article' : 'WebSite',
      name: title,
      description: description,
      url: canonicalURL,
      ...(type === 'website' && {
        publisher: {
          '@type': 'Organization',
          name: '松松健身',
          url: siteURL,
        },
      }),
    })} />
    
    <title>{title}</title>
    
    <!-- Dark mode initial setup -->
    <script is:inline>
      (function() {
        const theme = localStorage.getItem('theme') || 
          (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        if (theme === 'dark') {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body class="bg-bg dark:bg-gray-900 text-fg dark:text-gray-100 min-h-screen transition-colors duration-200">
    <header class="sticky top-0 z-50 bg-white/80 dark:bg-gray-900/80 backdrop-blur-sm border-b border-gray-200/60 dark:border-gray-700/60 transition-colors duration-200">
      <div class="container-wide flex items-center justify-between h-12">
        <a href={url('/')} class="font-semibold text-fg dark:text-gray-100 tracking-tight text-sm">
          松松健身
        </a>
        <nav class="hidden md:flex items-center gap-6">
          {primaryNav.map(({ href, label }) => (
            <a
              href={href}
              class:list={[
                'text-sm font-medium transition-colors',
                currentPath.startsWith(href) ? 'text-fg' : 'text-fg-secondary hover:text-fg',
              ]}
            >
              {label}
            </a>
          ))}
          <!-- 了解更多下拉 -->
          <div class="relative" id="more-nav-container">
            <button 
              id="more-nav-btn"
              class="nav-link flex items-center gap-0.5"
              aria-expanded="false"
              aria-haspopup="true"
              aria-controls="more-nav-menu"
            >
              了解更多
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M3 5l3 3 3-3" /></svg>
            </button>
            <div 
              id="more-nav-menu"
              class="absolute right-0 top-full pt-2 hidden"
              role="menu"
              aria-labelledby="more-nav-btn"
            >
              <div class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200/80 dark:border-gray-700 shadow-lg py-1 min-w-36">
                {moreNav.map(({ href, label }) => (
                  <a
                    href={href}
                    role="menuitem"
                    class:list={[
                      'block px-4 py-2 text-sm transition-colors',
                      currentPath.startsWith(href) ? 'text-fg font-medium bg-bg-secondary' : 'text-fg-secondary hover:text-fg hover:bg-bg-secondary',
                    ]}
                  >
                    {label}
                  </a>
                ))}
              </div>
            </div>
          </div>
          <!-- 主题切换按钮 -->
          <button
            id="theme-toggle"
            class="p-1.5 rounded-md text-fg-secondary hover:text-fg hover:bg-bg-secondary transition-colors"
            aria-label="切换主题"
            title="切换主题"
          >
            <!-- Sun icon (shown in dark mode) -->
            <svg id="sun-icon" class="hidden" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="5"/>
              <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
            </svg>
            <!-- Moon icon (shown in light mode) -->
            <svg id="moon-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
            </svg>
          </button>
        </nav>
        <button 
          id="menu-toggle" 
          class="md:hidden p-1 text-fg-secondary" 
          aria-label="菜单"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M3 5h14M3 10h14M3 15h14" />
          </svg>
        </button>
      </div>
      <nav 
        id="mobile-menu" 
        class="md:hidden hidden border-t border-gray-200/60 dark:border-gray-700/60 bg-white dark:bg-gray-900 pb-3 transition-colors duration-200"
        aria-label="移动端导航"
      >
        <div class="text-xs font-medium text-fg-tertiary px-6 pt-3 pb-1">工具</div>
        {primaryNav.map(({ href, label }) => (
          <a
            href={href}
            class:list={[
              'block px-6 py-2 text-sm',
              currentPath.startsWith(href) ? 'text-fg font-medium' : 'text-fg-secondary',
            ]}
          >
            {label}
          </a>
        ))}
        <div class="text-xs font-medium text-fg-tertiary px-6 pt-3 pb-1">了解更多</div>
        {moreNav.map(({ href, label }) => (
          <a
            href={href}
            class:list={[
              'block px-6 py-2 text-sm',
              currentPath.startsWith(href) ? 'text-fg font-medium' : 'text-fg-secondary',
            ]}
          >
            {label}
          </a>
        ))}
        <!-- 移动端主题切换 -->
        <div class="border-t border-gray-200/60 dark:border-gray-700/60 mt-3 pt-3 px-6">
          <button
            id="mobile-theme-toggle"
            class="flex items-center gap-2 text-sm text-fg-secondary"
          >
            <span>切换主题</span>
          </button>
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="border-t border-gray-200/60 dark:border-gray-700/60 mt-20 transition-colors duration-200">
      <div class="container py-8 text-fg-tertiary dark:text-gray-400 text-xs flex flex-col sm:flex-row justify-between gap-2">
        <p>内容基于 <a href="https://space.bilibili.com/2078781964" target="_blank" class="underline decoration-dotted hover:text-fg-secondary dark:hover:text-gray-300">B站@好人松松</a> 的健身 Excel 套表</p>
        <p>本站开源 · 不提供医疗建议</p>
      </div>
    </footer>

    <script is:inline>
      // 主题切换功能
      function initTheme() {
        const themeToggle = document.getElementById('theme-toggle');
        const mobileThemeToggle = document.getElementById('mobile-theme-toggle');
        const sunIcon = document.getElementById('sun-icon');
        const moonIcon = document.getElementById('moon-icon');
        const html = document.documentElement;
        
        function updateIcons() {
          const isDark = html.classList.contains('dark');
          if (sunIcon) sunIcon.classList.toggle('hidden', !isDark);
          if (moonIcon) moonIcon.classList.toggle('hidden', isDark);
        }
        
        function toggleTheme() {
          const isDark = html.classList.toggle('dark');
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
          updateIcons();
        }
        
        themeToggle?.addEventListener('click', toggleTheme);
        mobileThemeToggle?.addEventListener('click', toggleTheme);
        
        updateIcons();
      }

      // 移动端菜单切换
      const menuToggle = document.getElementById('menu-toggle');
      const mobileMenu = document.getElementById('mobile-menu');
      
      menuToggle?.addEventListener('click', () => {
        const isExpanded = mobileMenu?.classList.toggle('hidden') === false;
        menuToggle.setAttribute('aria-expanded', String(isExpanded));
      });

      // 桌面端下拉菜单（支持点击、悬停、键盘）
      const moreNavBtn = document.getElementById('more-nav-btn');
      const moreNavMenu = document.getElementById('more-nav-menu');
      let closeTimeout;

      function openMenu() {
        clearTimeout(closeTimeout);
        moreNavMenu?.classList.remove('hidden');
        moreNavBtn?.setAttribute('aria-expanded', 'true');
      }

      function closeMenu() {
        closeTimeout = setTimeout(() => {
          moreNavMenu?.classList.add('hidden');
          moreNavBtn?.setAttribute('aria-expanded', 'false');
        }, 150);
      }

      if (moreNavBtn && moreNavMenu) {
        // 鼠标悬停
        moreNavBtn.addEventListener('mouseenter', openMenu);
        moreNavMenu.addEventListener('mouseenter', openMenu);
        moreNavBtn.addEventListener('mouseleave', closeMenu);
        moreNavMenu.addEventListener('mouseleave', closeMenu);

        // 点击切换
        moreNavBtn.addEventListener('click', (e) => {
          e.preventDefault();
          const isOpen = !moreNavMenu.classList.contains('hidden');
          if (isOpen) {
            moreNavMenu.classList.add('hidden');
            moreNavBtn.setAttribute('aria-expanded', 'false');
          } else {
            openMenu();
          }
        });

        // 键盘支持
        moreNavBtn.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            const isOpen = !moreNavMenu.classList.contains('hidden');
            if (isOpen) {
              moreNavMenu.classList.add('hidden');
              moreNavBtn.setAttribute('aria-expanded', 'false');
            } else {
              openMenu();
              // 聚焦第一个菜单项
              moreNavMenu.querySelector('a')?.focus();
            }
          }
          if (e.key === 'Escape') {
            moreNavMenu.classList.add('hidden');
            moreNavBtn.setAttribute('aria-expanded', 'false');
            moreNavBtn.focus();
          }
        });

        // 菜单项键盘导航
        moreNavMenu.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') {
            moreNavMenu.classList.add('hidden');
            moreNavBtn.setAttribute('aria-expanded', 'false');
            moreNavBtn.focus();
          }
        });

        // 点击外部关闭
        document.addEventListener('click', (e) => {
          const container = document.getElementById('more-nav-container');
          if (container && !container.contains(e.target)) {
            moreNavMenu.classList.add('hidden');
            moreNavBtn.setAttribute('aria-expanded', 'false');
          }
        });
      }

      // 初始化主题
      initTheme();
    </script>
  </body>
</html>
