---
import Base from './Base.astro';

interface Props {
  title: string;
  description?: string;
  breadcrumb?: { label: string; href: string }[];
}

const { title, description, breadcrumb = [] } = Astro.props;
---

<Base title={`${title} — 松松健身`} description={description}>
  <article class="container py-10">
    {breadcrumb.length > 0 && (
      <nav class="flex items-center gap-1.5 text-xs text-fg-tertiary mb-6">
        <a href="/" class="hover:text-fg-secondary">首页</a>
        {breadcrumb.map(({ label, href }) => (
          <>
            <span>/</span>
            <a href={href} class="hover:text-fg-secondary">{label}</a>
          </>
        ))}
        <span>/</span>
        <span class="text-fg-secondary">{title}</span>
      </nav>
    )}

    <h1 class="heading-1 mb-8">{title}</h1>

    <div class="prose-content">
      <slot />
    </div>
  </article>
</Base>

<style is:global>
  .prose-content h2 {
    font-size: 1.375rem;
    font-weight: 600;
    color: var(--un-color-fg, #37352f);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    letter-spacing: -0.01em;
  }
  .prose-content h3 {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--un-color-fg, #37352f);
    margin-top: 1.75rem;
    margin-bottom: 0.5rem;
  }
  .prose-content p {
    color: #37352f;
    line-height: 1.75;
    margin-bottom: 1rem;
  }
  .prose-content ul, .prose-content ol {
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }
  .prose-content li {
    line-height: 1.75;
    margin-bottom: 0.25rem;
  }
  .prose-content strong {
    font-weight: 600;
  }
  .prose-content blockquote {
    border-left: 3px solid #e0e0de;
    padding-left: 1rem;
    color: #6b6b6b;
    margin: 1rem 0;
  }
  .prose-content code {
    font-family: "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: 0.875em;
    background: #f7f7f5;
    padding: 0.125rem 0.375rem;
    border-radius: 3px;
  }
  .prose-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0;
    font-size: 0.9375rem;
  }
  .prose-content th {
    text-align: left;
    font-weight: 600;
    padding: 0.5rem 0.75rem;
    border-bottom: 2px solid #e0e0de;
  }
  .prose-content td {
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid #f0f0ee;
  }
  .prose-content tr:hover td {
    background: #f7f7f5;
  }
</style>
