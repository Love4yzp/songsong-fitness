---
import Base from './Base.astro';
import { url } from '../utils/url';

interface Props {
  title: string;
  description?: string;
  activeTab?: 'home' | 'plan' | 'learn' | 'food' | 'more';
}

const { title, description, activeTab } = Astro.props;

const navItems = [
  { id: 'home', label: '首页', href: url('/'), icon: 'M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z' },
  { id: 'plan', label: '方案', href: url('/plan'), icon: 'M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2M9 5a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2M9 5a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2' },
  { id: 'learn', label: '学习', href: url('/learn'), icon: 'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253' },
  { id: 'food', label: '食物', href: url('/food'), icon: 'M18 8h1a4 4 0 0 1 0 8h-1M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8zM6 1v3M10 1v3M14 1v3' },
  { id: 'more', label: '更多', href: url('/more'), icon: 'M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 1 1 0-2 1 1 0 0 1 0 2zM12 13a1 1 0 1 1 0-2 1 1 0 0 1 0 2zM12 20a1 1 0 1 1 0-2 1 1 0 0 1 0 2z' },
];
---

<Base title={title} description={description} hideNav hideFooter>
  <div class="app-shell">
    <!-- Desktop Sidebar -->
    <aside class="sidebar">
      <div class="mb-8 mt-2">
        <div class="w-10 h-10 bg-accent rounded-xl flex items-center justify-center text-white font-bold text-xl shadow-lg shadow-accent/20">
          S
        </div>
      </div>
      {navItems.map((item) => (
        <a
          href={item.href}
          class={activeTab === item.id ? 'sidebar-item-active' : 'sidebar-item'}
          title={item.label}
        >
          <div class="w-6 h-6">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d={item.icon} />
            </svg>
          </div>
          <span>{item.label}</span>
        </a>
      ))}
      <!-- 主题切换 -->
      <button
        data-theme-toggle
        class="mt-auto mb-4 w-10 h-10 flex items-center justify-center rounded-xl text-fg-tertiary hover:text-fg hover:bg-bg-tertiary transition-colors"
        title="切换主题"
        aria-label="切换亮色/暗色主题"
      >
        <svg class="w-5 h-5 dark:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        <svg class="w-5 h-5 hidden dark:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
      </button>
    </aside>

    <!-- Main Content Area -->
    <div class="app-content md:ml-20">
      <slot />
    </div>

    <!-- Mobile Bottom Tabs -->
    <nav class="bottom-tabs">
      {navItems.map((item) => (
        <a
          href={item.href}
          class={activeTab === item.id ? 'tab-item-active' : 'tab-item'}
        >
          <div class="w-6 h-6">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d={item.icon} />
            </svg>
          </div>
          <span>{item.label}</span>
        </a>
      ))}
    </nav>
  </div>
</Base>
