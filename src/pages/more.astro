---
import AppShell from '../layouts/AppShell.astro';
import { url } from '../utils/url';

const items = [
  { label: '常见问题', href: url('/qa'), desc: '体重不动、在外吃饭、觉得饿……', icon: 'M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.56-2-1-3-1.072-1.715.464-3.155 2-3.155A2.5 2.5 0 0 1 14.5 8.5M12 17h.01' },
  { label: '训练计划', href: url('/training'), desc: '健身房三/四分化、居家方案', icon: 'M6.7 6.7l.7-2.2 2.2.7M17.3 17.3l-.7 2.2-2.2-.7M6.7 17.3l.7 2.2 2.2-.7M17.3 6.7l-.7-2.2-2.2.7M12 8v8M8 12h8' },
  { label: '关于本站', href: url('/about'), desc: '好人松松、内容来源、免责声明', icon: 'M12 16v-4M12 8h.01M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z' },
];
---

<AppShell title="更多 — 松松健身" activeTab="more">
  <div class="container py-8 px-4">
    <h1 class="heading-2 mb-6">更多</h1>

    <div class="space-y-3">
      {items.map(item => (
        <a
          href={item.href}
          class="flex items-center gap-4 p-4 bg-bg-secondary rounded-2xl border border-border-light active:scale-[0.98] transition-all hover:bg-bg-tertiary/50"
        >
          <div class="w-10 h-10 bg-bg-tertiary rounded-xl flex items-center justify-center text-accent">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d={item.icon} />
            </svg>
          </div>
          <div class="flex-1">
            <div class="text-sm font-bold text-fg">{item.label}</div>
            <div class="text-[10px] text-fg-tertiary">{item.desc}</div>
          </div>
          <svg class="w-4 h-4 text-fg-tertiary flex-none" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M6 4l4 4-4 4" />
          </svg>
        </a>
      ))}
    </div>
  </div>
</AppShell>
