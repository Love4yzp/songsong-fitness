---
import AppShell from '../layouts/AppShell.astro';
import { url } from '../utils/url';

const learnPages = [
  { href: url('/learn/philosophy'), title: '为什么有效', desc: '配额 > 卡路里、排除法 > 清单法' },
  { href: url('/learn/how-it-works'), title: '怎么运作', desc: '配额→食物两层模型' },
  { href: url('/learn/cutting'), title: '减脂须知', desc: '目标 BMI、速度、0.64 系数' },
  { href: url('/learn/bulking'), title: '增肌须知', desc: '增速、0.84 系数、力训要求' },
];

const qaHighlights = [
  { href: url('/qa/stall'), title: '体重不动了', tag: '最常见' },
];

const trainingPlans = [
  { title: '健身房三分化', desc: '3天/周 · 新手推荐', href: url('/training') },
  { title: '健身房四分化', desc: '4天/周 · 进阶', href: url('/training') },
  { title: '居家三分化', desc: '弹力带/哑铃', href: url('/training') },
];
---

<AppShell title="松松健身 — 用配额吃饭，不算卡路里" activeTab="home">
  <div class="container py-6 px-4 space-y-10">

    <!-- Hero: 精简，一句话说清楚 -->
    <section>
      <h1 class="text-2xl md:text-4xl font-black text-fg-strong tracking-tight leading-tight mb-3">
        管住嘴，不用数卡路里。
      </h1>
      <p class="text-sm text-fg-secondary max-w-md leading-relaxed mb-5">
        基于 B站@好人松松 的健身方法论。输入体重、选个场景，每日三餐配额自动算好。
      </p>
      <a href={url('/plan')} class="btn-primary inline-flex shadow-lg shadow-accent/20">
        开始制定方案
        <svg class="w-4 h-4 ml-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </section>

    <!-- 理解体系 -->
    <section>
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-xs font-black text-fg-secondary uppercase tracking-wider">理解体系</h2>
        <a href={url('/learn')} class="text-[10px] font-bold text-accent">查看全部</a>
      </div>
      <div class="grid grid-cols-2 gap-2">
        {learnPages.map(p => (
          <a href={p.href} class="p-3 bg-bg-secondary rounded-xl border border-border-light hover:bg-bg-tertiary/50 transition-colors active:scale-[0.98]">
            <div class="text-sm font-bold text-fg mb-0.5">{p.title}</div>
            <div class="text-[10px] text-fg-tertiary leading-relaxed">{p.desc}</div>
          </a>
        ))}
      </div>
    </section>

    <!-- 常见问题 -->
    <section>
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-xs font-black text-fg-secondary uppercase tracking-wider">常见问题</h2>
        <a href={url('/qa')} class="text-[10px] font-bold text-accent">查看全部</a>
      </div>
      <div class="space-y-2">
        {qaHighlights.map(q => (
          <a href={q.href} class="flex items-center justify-between p-3 bg-bg-secondary rounded-xl border border-border-light hover:bg-bg-tertiary/50 transition-colors active:scale-[0.98]">
            <span class="text-sm font-bold text-fg">{q.title}</span>
            <span class="tag-pill bg-warning/10 text-warning font-bold">{q.tag}</span>
          </a>
        ))}
      </div>
    </section>

    <!-- 训练计划 -->
    <section>
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-xs font-black text-fg-secondary uppercase tracking-wider">训练计划</h2>
        <a href={url('/training')} class="text-[10px] font-bold text-accent">查看全部</a>
      </div>
      <div class="flex gap-2 overflow-x-auto pb-1 -mx-4 px-4 snap-x">
        {trainingPlans.map(t => (
          <a href={t.href} class="flex-none w-40 p-3 bg-bg-secondary rounded-xl border border-border-light hover:bg-bg-tertiary/50 transition-colors snap-start active:scale-[0.98]">
            <div class="text-sm font-bold text-fg mb-0.5">{t.title}</div>
            <div class="text-[10px] text-fg-tertiary">{t.desc}</div>
          </a>
        ))}
      </div>
    </section>

    <!-- 食物数据库 -->
    <section>
      <a href={url('/food')} class="flex items-center gap-4 p-4 bg-bg-secondary rounded-2xl border border-border-light hover:bg-bg-tertiary/50 transition-colors active:scale-[0.98]">
        <div class="w-10 h-10 bg-bg-tertiary rounded-xl flex items-center justify-center text-accent">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 8h1a4 4 0 0 1 0 8h-1M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8zM6 1v3M10 1v3M14 1v3" />
          </svg>
        </div>
        <div class="flex-1">
          <div class="text-sm font-bold text-fg">食物数据库</div>
          <div class="text-[10px] text-fg-tertiary">113 种日常食物的营养率，输入克数自动计算</div>
        </div>
        <svg class="w-4 h-4 text-fg-tertiary flex-none" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M6 4l4 4-4 4" />
        </svg>
      </a>
    </section>

    <!-- 归属 -->
    <footer class="text-center pt-4 pb-2">
      <p class="text-[10px] text-fg-tertiary">
        内容来源：B站 <a href="https://space.bilibili.com/2078781964" target="_blank" rel="noopener" class="text-accent font-bold">@好人松松</a>
      </p>
    </footer>
  </div>
</AppShell>
