---
import AppShell from '../../layouts/AppShell.astro';
import { getCollection } from 'astro:content';
import { url } from '../../utils/url';

const entries = (await getCollection('training'))
  .filter(e => !e.data.draft);
---

<AppShell title="训练计划 — 松松健身" activeTab="more">
  <div class="container py-8 px-4">

    <h1 class="heading-1 mb-2">训练计划</h1>
    <p class="muted-text mb-8">
      选一个适合你的分化方案。多关节动作 8-12 次至力竭，组间休息 2-3 分钟。
    </p>

    {entries.length > 0 ? (
      <div class="space-y-3">
        {entries.map(entry => (
          <a href={url(`/training/${entry.id}`)} class="card flex items-start gap-4 block">
            <div class="flex-1">
              <div class="flex items-center gap-2 flex-wrap">
                <span class="text-sm font-medium text-fg">{entry.data.title}</span>
                {entry.data.equipment.map(eq => (
                  <span class="tag-pill bg-info/15 text-info">{eq}</span>
                ))}
              </div>
              <div class="text-xs text-fg-tertiary mt-1">{entry.data.description}</div>
            </div>
            <svg class="w-4 h-4 text-fg-tertiary mt-0.5 flex-none" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M6 4l4 4-4 4" />
            </svg>
          </a>
        ))}
      </div>
    ) : (
      <div class="callout-tip">
        <strong>内容建设中</strong> — 训练计划正在整理，敬请期待。
      </div>
    )}

    <div class="mt-10">
      <h2 class="heading-2 mb-4">通用原则</h2>
      <div class="space-y-3 text-sm text-fg-secondary leading-relaxed">
        <p><strong>频率：</strong>3 天/周足够，4-5 天饱和，6 天没必要。</p>
        <p><strong>重量：</strong>8-12 次至力竭是增肌最佳区间（5-30 次都有效）。</p>
        <p><strong>休息：</strong>多关节动作 2-3 分钟，单关节动作 1-1.5 分钟。</p>
        <p><strong>时长：</strong>每次 1-1.5 小时。</p>
        <p><strong>至力竭：</strong>不是必须的。危险动作（深蹲、卧推、过顶推举）不要去力竭。</p>
        <p><strong>女性调整：</strong>胸部训练隔次跳过，重量偏轻 10-15 次，强调臀部。</p>
      </div>
    </div>

    <div class="mt-8 callout-tip">
      <strong>配套视频：</strong>
      <a href="https://www.bilibili.com/video/BV1Hk4y187jF" target="_blank" class="underline decoration-dotted">
        健身新手的完全训练手册（BV1Hk4y187jF）
      </a>
    </div>
  </div>
</AppShell>
