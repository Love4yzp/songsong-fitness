---
import AppShell from '../../layouts/AppShell.astro';
import { getCollection } from 'astro:content';
import { url } from '../../utils/url';

const entries = (await getCollection('qa'))
  .filter(e => !e.data.draft);
---

<AppShell title="常见问题 — 松松健身" activeTab="more">
  <div class="container py-8 px-4">

    <h1 class="heading-1 mb-2">常见问题</h1>
    <p class="muted-text mb-8">
      按你遇到的问题找答案，不按编号。内容整合自好人松松的减脂 26 问和增肌 18 问。
    </p>

    {entries.length > 0 ? (
      <div class="space-y-3">
        {entries.map(entry => (
          <a href={url(`/qa/${entry.id}`)} class="card flex items-start gap-4 block">
            <div class="flex-1">
              <div class="flex items-center gap-2">
                <div class="text-sm font-medium text-fg">{entry.data.title}</div>
                {entry.data.symptoms.length > 0 && (
                  <span class="tag-pill bg-error/15 text-error">{entry.data.symptoms[0]}</span>
                )}
              </div>
              <div class="text-xs text-fg-tertiary mt-1">{entry.data.description}</div>
            </div>
            <svg class="w-4 h-4 text-fg-tertiary mt-0.5 flex-none" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M6 4l4 4-4 4" />
            </svg>
          </a>
        ))}
      </div>
    ) : (
      <div class="callout-tip">
        <strong>内容建设中</strong> — 常见问题正在整理，敬请期待。
      </div>
    )}
  </div>
</AppShell>
