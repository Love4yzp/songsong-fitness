---
import Base from '../../layouts/Base.astro';

const topics = [
  {
    title: '体重不动了',
    href: '/qa/stall',
    desc: '执行了两周体重不掉（减脂）/ 一个月不长（增肌）',
    tag: '最常见',
    tagColor: 'bg-tag-red text-red-800',
  },
  {
    title: '在外面怎么吃',
    href: '/qa/eating-out',
    desc: '食堂、外卖、餐馆、聚餐的实操指南',
  },
  {
    title: '觉得饿',
    href: '/qa/hunger',
    desc: '高饱腹感食物选择 + 有氧置换饮食的安全阀',
  },
  {
    title: '喝酒',
    href: '/qa/alcohol',
    desc: '1 两白酒 = 1 瓶啤酒 = 200 大卡 = 50g 碳水',
  },
  {
    title: '特殊体质',
    href: '/qa/medical',
    desc: '高尿酸/痛风、胰岛素抵抗/二型糖尿病的配额调整',
  },
  {
    title: '常见误区',
    href: '/qa/myths',
    desc: '体脂秤不可信、每天体重无意义、别追求同时增肌减脂…',
  },
  {
    title: '实操细节',
    href: '/qa/practical',
    desc: '称重方法、固定重量食物、便携碳水、力训时间切换',
  },
];
---

<Base title="常见问题 — 松松健身">
  <div class="container py-10">
    <nav class="flex items-center gap-1.5 text-xs text-fg-tertiary mb-6">
      <a href="/" class="hover:text-fg-secondary">首页</a>
      <span>/</span>
      <span class="text-fg-secondary">常见问题</span>
    </nav>

    <h1 class="heading-1 mb-2">常见问题</h1>
    <p class="muted-text mb-8">
      按你遇到的问题找答案，不按编号。内容整合自好人松松的减脂 26 问和增肌 18 问。
    </p>

    <div class="space-y-3">
      {topics.map(({ title, href, desc, tag, tagColor }) => (
        <a href={href} class="card flex items-start gap-4 block">
          <div class="flex-1">
            <div class="flex items-center gap-2">
              <div class="text-sm font-medium text-fg">{title}</div>
              {tag && <span class:list={['tag-pill', tagColor || 'bg-tag-blue text-blue-800']}>{tag}</span>}
            </div>
            <div class="text-xs text-fg-tertiary mt-1">{desc}</div>
          </div>
          <svg class="w-4 h-4 text-fg-tertiary mt-0.5 flex-none" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M6 4l4 4-4 4" />
          </svg>
        </a>
      ))}
    </div>
  </div>
</Base>
