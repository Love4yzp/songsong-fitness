---
import AppShell from '../../layouts/AppShell.astro';
import { getCollection } from 'astro:content';
import { url } from '../../utils/url';

const entries = (await getCollection('learn'))
  .filter(e => !e.data.draft)
  .sort((a, b) => a.data.order - b.data.order);
---

<AppShell title="理解体系 — 松松健身" activeTab="learn">
  <div class="container py-8 px-4">

    <h1 class="heading-1 mb-2">理解体系</h1>
    <p class="muted-text mb-8">先搞懂为什么，再看怎么做。</p>

    <div class="space-y-3">
      {entries.map(entry => (
        <a href={url(`/learn/${entry.id}`)} class="card flex items-start gap-4 block">
          <div class="flex-1">
            <div class="text-sm font-medium text-fg">{entry.data.title}</div>
            <div class="text-xs text-fg-tertiary mt-1">{entry.data.description}</div>
          </div>
          <svg class="w-4 h-4 text-fg-tertiary mt-0.5 flex-none" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M6 4l4 4-4 4" />
          </svg>
        </a>
      ))}
    </div>
  </div>
</AppShell>
